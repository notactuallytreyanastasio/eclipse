FROM rust:slim-bookworm AS builder

RUN cargo install deciduous

FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    libssl3 ca-certificates socat && \
    rm -rf /var/lib/apt/lists/*

COPY --from=builder /usr/local/cargo/bin/deciduous /usr/local/bin/deciduous

WORKDIR /data

CMD sh -c 'deciduous serve -p 3001 & sleep 1 && socat TCP-LISTEN:3000,fork,reuseaddr,bind=0.0.0.0 TCP:127.0.0.1:3001'
